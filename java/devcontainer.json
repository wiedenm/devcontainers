{
  "name": "knime-hub-catalog-service",
  "image": "mcr.microsoft.com/devcontainers/java:21",
  "remoteUser": "vscode",
  "features": {
    "ghcr.io/devcontainers/features/node:latest": {},
    "ghcr.io/anthropics/devcontainer-features/claude-code:latest": {},
    "ghcr.io/devcontainers/features/docker-in-docker:latest": {
      // `"moby": true` is the default but not supported on Debian Trixie, which
      // is what mcr.microsoft.com/devcontainers/java:21 currently ships on.
      "moby": false
    }
  },
  "mounts": [
    "source=${localEnv:HOME}/.claude,target=/vscode/.claude,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.claude.json,target=/vscode/.claude.json,type=bind,consistency=cached",
    // Include files symlinked from the .claude directory above.
    "source=${localEnv:HOME}/dev/claude-config,target=${localEnv:HOME}/dev/claude-config,type=bind,consistency=cached"
  ],
  "containerEnv": {
    "CLAUDE_CONFIG_DIR": "/vscode/.claude",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1"
  },
  "runArgs": ["--env-file", "${localEnv:HOME}/dev/claude-config/.credentials/claude_code.env"]
}